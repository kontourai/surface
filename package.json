{
  "name": "@kontourai/surface",
  "version": "2.11.0",
  "description": "Shared transparency foundation under Kontour's products. Claims, evidence, freshness, and gaps in one inspectable shape.",
  "license": "Apache-2.0",
  "type": "module",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kontourai/surface.git"
  },
  "homepage": "https://kontourai.io/surface",
  "bugs": {
    "url": "https://github.com/kontourai/surface/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "surface": "bin/surface.mjs"
  },
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./trust-panel/element": {
      "types": "./dist/src/trust-panel/surface-trust-panel.d.ts",
      "import": "./dist/src/trust-panel/surface-trust-panel.js"
    }
  },
  "files": [
    "bin/",
    "dist/src/",
    "schemas/",
    "examples/*.json",
    "examples/console-multi-producer/*.json",
    "examples/console-multi-producer/README.md",
    "examples/external-adapter/README.md",
    "examples/external-adapter/example-input.json",
    "examples/external-adapter/package.json",
    "examples/external-adapter/src/",
    "examples/external-adapter/tsconfig.json",
    "examples/postgres-claim-store/README.md",
    "examples/postgres-claim-store/package.json",
    "examples/postgres-claim-store/schema.sql",
    "examples/postgres-claim-store/src/",
    "examples/postgres-claim-store/tsconfig.json",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:console-assets && rm -rf dist && tsc && npm run build:trust-panel-module",
    "build:console-assets": "node scripts/build-console-assets.mjs",
    "build:trust-panel-module": "node scripts/build-trust-panel-module.mjs",
    "check:console-assets": "node scripts/build-console-assets.mjs --check",
    "check:trust-panel-module": "node scripts/build-trust-panel-module.mjs --check",
    "typecheck": "npm run check:console-assets && npm run check:trust-panel-module && tsc --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js && node --test dist/tests/serial/*.test.js",
    "test:external-adapter": "npm run build && node --test dist/tests/serial/external-adapter.test.js",
    "test:package-smoke": "npm run build && node --test dist/tests/package-smoke/*.test.js",
    "test:browser": "playwright test",
    "test:coverage": "npm run build && node --test --experimental-test-coverage dist/tests/*.test.js && node --test dist/tests/serial/*.test.js",
    "docs:build": "node scripts/sync-ui-assets.mjs && node scripts/build-pages-site.mjs",
    "sync:ui-assets": "node scripts/sync-ui-assets.mjs",
    "check:ui-assets": "node scripts/sync-ui-assets.mjs --check",
    "check:doc-links": "node scripts/check-doc-links.mjs",
    "check:generated-boundaries": "node scripts/check-generated-boundaries.mjs",
    "check:package-contents": "node scripts/check-package-contents.mjs",
    "surface:report": "npm run build && node bin/surface.mjs report",
    "surface:summary": "npm run build && node bin/surface.mjs report --format summary",
    "verify": "node scripts/check-content-boundary.cjs && npm run check:decisions && npm run check:doc-links && npm run check:generated-boundaries && npm run typecheck && npm test && npm run docs:build && npm run check:ui-assets && npm run check:console-token-drift && npm run check:package-contents && npm run test:external-adapter && npm run test:package-smoke && npm run surface:summary && npm run test:browser",
    "prepare": "npm run build",
    "check:content-boundary": "node scripts/check-content-boundary.cjs",
    "check:decisions": "node scripts/check-decisions.cjs check",
    "gen:decisions-index": "node scripts/check-decisions.cjs gen-index",
    "freeze:adrs": "node scripts/freeze-adrs.mjs",
    "setup:repo-hooks": "node scripts/setup-repo-hooks.cjs",
    "validate:repo-hooks": "node scripts/validate-repo-hooks.cjs",
    "release:trust-bundle": "node scripts/release-trust-bundle.mjs",
    "check:console-token-drift": "node scripts/check-console-token-drift.mjs",
    "verify:trust-bundle": "node scripts/verify-trust-bundle.mjs",
    "sync:schemas": "node scripts/sync-schemas.mjs"
  },
  "devDependencies": {
    "@kontourai/ui": "^1.1.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "ajv": "^8.20.0",
    "hachure": "^0.14.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  },
  "optionalDependencies": {
    "@sigstore/sign": "^4.1.1",
    "@sigstore/verify": "^3.1.1"
  }
}
