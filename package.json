{
  "name": "@kontourai/surface",
  "version": "0.2.0",
  "description": "Evidence-backed trust surface for products built with humans and AI agents.",
  "license": "Apache-2.0",
  "type": "module",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kontourai/surface.git"
  },
  "homepage": "https://kontourai.io/surface",
  "bugs": {
    "url": "https://github.com/kontourai/surface/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "surface": "bin/surface.mjs"
  },
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "bin/",
    "dist/examples/",
    "dist/src/",
    "dist/bin/",
    "schemas/",
    "examples/",
    "docs/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "test:coverage": "npm run build && node --test --experimental-test-coverage dist/tests/*.test.js",
    "docs:build": "node scripts/build-pages-site.mjs",
    "surface:report": "npm run build && node bin/surface.mjs report",
    "surface:summary": "npm run build && node bin/surface.mjs report --format summary",
    "verify": "npm run typecheck && npm test && npm run docs:build && npm run surface:summary",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
