{
  "name": "@kontourai/surface",
  "version": "0.5.1",
  "description": "Shared transparency foundation under Kontour's products. Claims, evidence, freshness, and gaps in one inspectable shape.",
  "license": "Apache-2.0",
  "type": "module",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kontourai/surface.git"
  },
  "homepage": "https://kontourai.io/surface",
  "bugs": {
    "url": "https://github.com/kontourai/surface/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "surface": "bin/surface.mjs"
  },
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "bin/",
    "dist/src/",
    "schemas/",
    "examples/*.json",
    "examples/external-adapter/README.md",
    "examples/external-adapter/fixture.json",
    "examples/external-adapter/package.json",
    "examples/external-adapter/src/",
    "examples/external-adapter/tsconfig.json",
    "docs/",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "test:external-adapter": "npm run build && node --test dist/tests/external-adapter.test.js",
    "test:browser": "playwright test",
    "test:coverage": "npm run build && node --test --experimental-test-coverage dist/tests/*.test.js",
    "docs:build": "node scripts/sync-console-kit-assets.mjs && node scripts/build-pages-site.mjs",
    "sync:console-kit": "node scripts/sync-console-kit-assets.mjs",
    "check:console-kit-assets": "node scripts/sync-console-kit-assets.mjs --check",
    "surface:report": "npm run build && node bin/surface.mjs report",
    "surface:summary": "npm run build && node bin/surface.mjs report --format summary",
    "verify": "node scripts/check-content-boundary.cjs && npm run typecheck && npm test && npm run docs:build && npm run check:console-kit-assets && npm run surface:summary && npm run test:browser",
    "prepare": "npm run build",
    "check:content-boundary": "node scripts/check-content-boundary.cjs",
    "setup:repo-hooks": "node scripts/setup-repo-hooks.cjs",
    "validate:repo-hooks": "node scripts/validate-repo-hooks.cjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.6.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
