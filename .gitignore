node_modules/

# Generated build and verification output. Source lives in src/, docs/, schemas/,
# examples/, scripts/, and tests/; these paths are regenerated locally.
dist/
docs-site/
test-results/
playwright-report/
.npm-pack-cache/
*.tsbuildinfo

# Local workflow/runtime telemetry. Durable agent bundle files may live in
# .agents/ and are intentionally not ignored.
.omx/
.flow-agents/

# Surface derived state — regenerated each run, never check in.
# See SURFACE-PRIVACY.md for the input-vs-derived split.
.surface/claims/
.surface/reports/
.surface/runs/
.surface/cache/
