{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kontourai.io/schemas/surface/trust-report.schema.json",
  "title": "Kontour Surface Trust Report",
  "type": "object",
  "required": ["schemaVersion", "id", "generatedAt", "source", "claims", "evidence", "policies", "events", "authorityTrace", "evidenceRequirementsByClaimId", "transparencyGaps", "subjectGroups", "claimGroupRollups", "summary"],
  "properties": {
    "schemaVersion": { "enum": [2, 3] },
    "id": { "type": "string" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "claims": { "type": "array", "items": { "$ref": "claim.schema.json" } },
    "evidence": { "type": "array", "items": { "$ref": "evidence.schema.json" } },
    "policies": { "type": "array", "items": { "$ref": "verification-policy.schema.json" } },
    "events": { "type": "array", "items": { "$ref": "verification-event.schema.json" } },
    "claimGroups": {
      "type": "array",
      "items": { "$ref": "trust-input.schema.json#/$defs/claimGroup" }
    },
    "authorityTrace": {
      "type": "array",
      "items": { "$ref": "trust-input.schema.json#/$defs/authorityTrace" }
    },
    "evidenceRequirementsByClaimId": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "requiredEvidenceTypes": {
            "type": "array",
            "items": { "enum": ["source_excerpt", "test_output", "human_attestation", "calculation_trace", "document_citation", "crawl_observation", "policy_rule"] }
          },
          "requiredMethods": {
            "type": "array",
            "items": { "enum": ["observation", "extraction", "validation", "corroboration", "attestation", "auditability", "anchoring", "monitoring"] }
          },
          "requiresCorroboration": { "type": "boolean" },
          "requiredAuthority": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "transparencyGaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "claimId", "type", "severity", "message", "createdAt"],
        "properties": {
          "id": { "type": "string" },
          "claimId": { "type": "string" },
          "type": { "enum": ["contradiction", "provenance_gap", "policy_violation", "freshness_breach", "corroboration_absent", "unsupported_inference"] },
          "severity": { "enum": ["low", "medium", "high", "critical"] },
          "message": { "type": "string" },
          "evidenceIds": { "type": "array", "items": { "type": "string" } },
          "policyId": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "metadata": { "type": "object" }
        },
        "additionalProperties": false
      }
    },
    "identityLinks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["subjects"],
        "properties": {
          "subjects": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["subjectType", "subjectId"],
              "properties": {
                "subjectType": { "type": "string" },
                "subjectId": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "reason": { "type": "string" },
          "attestedBy": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "subjectGroups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["canonicalKey", "members", "claimIds"],
        "properties": {
          "canonicalKey": { "type": "string" },
          "members": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["subjectType", "subjectId"],
              "properties": {
                "subjectType": { "type": "string" },
                "subjectId": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "claimIds": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "claimGroupRollups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "kind", "status", "claimIds", "requirements", "summary"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "kind": { "enum": ["claimGroup", "framework", "requirement-set"] },
          "status": { "enum": ["unknown", "proposed", "verified", "stale", "disputed", "superseded", "rejected"] },
          "description": { "type": "string" },
          "claimIds": { "type": "array", "items": { "type": "string" } },
          "requirements": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "title", "status", "claimIds", "required", "severity", "verifiedClaims", "staleClaims", "disputedClaims", "unsupportedClaims", "missingClaimIds"],
              "properties": {
                "id": { "type": "string" },
                "title": { "type": "string" },
                "status": { "enum": ["unknown", "proposed", "verified", "stale", "disputed", "superseded", "rejected"] },
                "claimIds": { "type": "array", "items": { "type": "string" } },
                "required": { "type": "boolean" },
                "severity": { "enum": ["low", "medium", "high", "critical"] },
                "verifiedClaims": { "type": "array", "items": { "type": "string" } },
                "staleClaims": { "type": "array", "items": { "type": "string" } },
                "disputedClaims": { "type": "array", "items": { "type": "string" } },
                "unsupportedClaims": { "type": "array", "items": { "type": "string" } },
                "missingClaimIds": { "type": "array", "items": { "type": "string" } },
                "validationStrategy": { "$ref": "trust-input.schema.json#/$defs/validationStrategy" },
                "metadata": { "type": "object" }
              },
              "additionalProperties": false
            }
          },
          "summary": {
            "type": "object",
            "required": ["totalRequirements", "requiredRequirements", "verifiedRequirements", "staleRequirements", "disputedRequirements", "unsupportedRequirements", "missingClaims", "verificationCoverage"],
            "properties": {
              "totalRequirements": { "type": "number" },
              "requiredRequirements": { "type": "number" },
              "verifiedRequirements": { "type": "number" },
              "staleRequirements": { "type": "number" },
              "disputedRequirements": { "type": "number" },
              "unsupportedRequirements": { "type": "number" },
              "missingClaims": { "type": "number" },
              "verificationCoverage": { "type": "number" }
            },
            "additionalProperties": false
          },
          "metadata": { "type": "object" }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": ["totalClaims", "byStatus", "bySurface", "transparencyGapsByType", "highImpactUnsupported", "staleClaims", "disputedClaims"],
      "properties": {
        "totalClaims": { "type": "number" },
        "byStatus": { "type": "object" },
        "bySurface": { "type": "object" },
        "transparencyGapsByType": { "type": "object" },
        "highImpactUnsupported": { "type": "array", "items": { "type": "string" } },
        "staleClaims": { "type": "array", "items": { "type": "string" } },
        "disputedClaims": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
