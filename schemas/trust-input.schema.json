{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kontour.ai/schemas/surface/trust-input.schema.json",
  "title": "Surface TrustInput",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "source", "claims", "evidence", "policies", "events"],
  "properties": {
    "schemaVersion": { "enum": [2, 3] },
    "source": { "type": "string" },
    "claims": {
      "type": "array",
      "items": { "type": "object" }
    },
    "evidence": {
      "type": "array",
      "items": { "type": "object" }
    },
    "policies": {
      "type": "array",
      "items": { "type": "object" }
    },
    "events": {
      "type": "array",
      "items": { "type": "object" }
    },
    "identityLinks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["subjects"],
        "properties": {
          "subjects": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["subjectType", "subjectId"],
              "properties": {
                "subjectType": { "type": "string" },
                "subjectId": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "reason": { "type": "string" },
          "attestedBy": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "not": {
    "anyOf": [
      { "required": ["id"] },
      { "required": ["generatedAt"] },
      { "required": ["summary"] },
      { "required": ["faultLines"] },
      { "required": ["proofRequirementsByClaimId"] }
    ]
  }
}
