{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kontour.ai/schemas/surface/trust-input.schema.json",
  "title": "Surface TrustInput",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "source", "claims", "evidence", "policies", "events"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "source": { "type": "string" },
    "claims": {
      "type": "array",
      "items": { "type": "object" }
    },
    "evidence": {
      "type": "array",
      "items": { "type": "object" }
    },
    "policies": {
      "type": "array",
      "items": { "type": "object" }
    },
    "events": {
      "type": "array",
      "items": { "type": "object" }
    }
  },
  "not": {
    "anyOf": [
      { "required": ["id"] },
      { "required": ["generatedAt"] },
      { "required": ["summary"] },
      { "required": ["faultLines"] },
      { "required": ["proofRequirementsByClaimId"] }
    ]
  }
}
