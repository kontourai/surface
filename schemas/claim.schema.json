{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hachure.org/schemas/claim.schema.json",
  "title": "Hachure Claim",
  "type": "object",
  "required": ["id", "subjectType", "subjectId", "claimType", "fieldOrBehavior", "value", "createdAt", "updatedAt"],
  "properties": {
    "id": { "type": "string" },
    "subjectType": { "type": "string" },
    "subjectId": { "type": "string" },
    "facet": { "type": "string" },
    "claimType": { "type": "string" },
    "fieldOrBehavior": { "type": "string" },
    "value": {},
    "status": { "$ref": "#/$defs/trustStatus" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "expiresAt": {
      "description": "Optional absolute validity window: ISO-8601 instant after which the claim is no longer fresh. Canonical when both expiresAt and ttlSeconds are present (expiresAt wins). Behaviour is derived by Surface, not by this schema.",
      "type": "string",
      "format": "date-time"
    },
    "ttlSeconds": {
      "description": "Optional relative validity window in seconds, resolved by the deriver against the governing verification event's verifiedAt (falling back to createdAt). If expiresAt is also present, expiresAt takes precedence. Behaviour is derived by Surface, not by this schema.",
      "type": "integer",
      "minimum": 0
    },
    "impactLevel": { "enum": ["low", "medium", "high", "critical"] },
    "materiality": { "enum": ["low", "medium", "high"] },
    "currentIntegrityRef": { "type": "string" },
    "currentIntegrityAnchor": { "$ref": "#/$defs/integrityAnchor" },
    "verificationPolicyId": { "type": "string" },
    "confidenceBasis": { "type": "object" },
    "subjectAliases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["subjectType", "subjectId"],
        "properties": {
          "subjectType": { "type": "string" },
          "subjectId": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "derivedFrom": {
      "type": "array",
      "items": { "type": "string" }
    },
    "derivationEdges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["inputClaimId"],
        "properties": {
          "inputClaimId": { "type": "string" },
          "method": { "enum": ["sum", "max", "min", "model", "rule-application", "copy", "normalization", "manual"] },
          "role": { "type": "string" },
          "supportStrength": { "enum": ["weak", "moderate", "strong"] },
          "rationale": { "type": "string" },
          "sensitivity": {
            "type": "object",
            "$comment": "Optional sensitivity range for a quantitative derivation edge: a threshold/estimate travels with its bounds and basis so it is never a bare number. Pass-through metadata; not consulted by the status function.",
            "required": ["low", "high", "basis"],
            "properties": {
              "low": { "type": "number" },
              "high": { "type": "number" },
              "basis": { "type": "string" }
            },
            "additionalProperties": false
          },
          "metadata": { "type": "object" }
        },
        "additionalProperties": false
      }
    },
    "qualifiers": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "metadata": { "type": "object" },
    "producerStatus": { "$ref": "#/$defs/trustStatus" },
    "freshness": {
      "type": "object",
      "required": ["asOf", "stale"],
      "properties": {
        "asOf": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "stale": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "trustStatus": {
      "enum": ["unknown", "proposed", "assumed", "verified", "stale", "disputed", "superseded", "rejected", "revoked"]
    },
    "integrityAnchor": {
      "type": "object",
      "required": ["id", "kind", "algorithm", "value", "sourceRef"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "enum": ["hash", "signature", "transparency_log", "timestamp", "external_ref", "other"] },
        "algorithm": { "type": "string" },
        "value": { "type": "string" },
        "sourceRef": { "type": "string" },
        "observedAt": { "type": "string", "format": "date-time" },
        "verificationStatus": { "enum": ["unverified", "verified", "failed", "not_applicable"] },
        "verifiedAt": { "type": "string", "format": "date-time" },
        "verifiedBy": { "type": "string" },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
